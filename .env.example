TOKEN=
COMMAND_LOG_WEBHOOK_URL=
LOG_LEVEL=INFO
ENABLE_KEEP_ALIVE=true
PORT=8080
EMOJI_SYNC_STARTUP_AUTO_SYNC=true

# Lavalink/Wavelink music node. Recommended: run your own Lavalink server.
LAVALINK_ENABLED=true
LAVALINK_IDENTIFIER=main
LAVALINK_URI=
LAVALINK_PORT=2333
LAVALINK_SECURE=false
LAVALINK_PASSWORD=
LAVALINK_HEARTBEAT=15
LAVALINK_RETRIES=3
LAVALINK_PRECHECK=true
# Optional advanced format:
# LAVALINK_NODES_JSON=[{"identifier":"main","uri":"http://127.0.0.1:2333","password":"youshallnotpass"}]

# Optional: comma-separated Discord server IDs to copy custom emojis from.
# Example: EMOJI_SYNC_SOURCE_GUILD_IDS=123456789012345678,987654321098765432
EMOJI_SYNC_SOURCE_GUILD_IDS=
EMOJI_SYNC_CODE_EMOJIS=true

# Optional: comma-separated local folders containing emoji image files.
# Defaults are configured in config.yml: data/emojis, assets/emojis
EMOJI_SYNC_ASSET_DIRS=
